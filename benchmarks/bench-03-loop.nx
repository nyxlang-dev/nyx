// bench-03-loop.nx — Tight arithmetic loop (raw codegen quality)
fn main() {
    let N: int = 100000000
    let start: int = time_us()

    var sum: int = 0
    var i: int = 0
    while i < N {
        sum = sum + i * i
        i = i + 1
    }

    let end: int = time_us()
    let elapsed: int = end - start
    print("sum: " + int_to_string(sum))
    print("time_us: " + int_to_string(elapsed))
    return 0
}
