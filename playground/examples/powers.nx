// powers.nx
// Potencia recursiva: base^exp

fn power(base, exp) {
    if exp == 0 {
        return 1
    } else {
        return base * power(base, exp - 1)
    }
}

fn main() {
    print(power(2, 0))   // 1
    print(power(2, 1))   // 2
    print(power(2, 5))   // 32
    print(power(2, 10))  // 1024
    print(power(3, 3))   // 27
    print(power(5, 4))   // 625
}