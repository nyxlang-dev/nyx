// gcd.nx
// Máximo Común Divisor (Algoritmo de Euclides)

fn gcd(a, b) {
    if b == 0 {
        return a
    } else {
        let resto = a - b * (a / b)
        return gcd(b, resto)
    }
}

fn main() {
    print(gcd(48, 18))   // 6
    print(gcd(100, 50))  // 50
    print(gcd(17, 13))   // 1
    print(gcd(270, 192)) // 6
}
