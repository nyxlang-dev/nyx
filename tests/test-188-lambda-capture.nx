// Test 188: Lambda capture of outer function parameters
// Bug: inline lambda can't access enclosing function's parameters

fn make_adder(n: int) -> Fn(int) -> int {
    return fn(x: int) -> int { return n + x }
}

fn make_greeting(prefix: String) -> Fn(String) -> String {
    return fn(name: String) -> String { return prefix + " " + name }
}

fn main() {
    let add5 = make_adder(5)
    print(add5(10))
    print(add5(20))

    let hello = make_greeting("Hello")
    print(hello("World"))
}
