fn main() {
    // Test 1: literal string
    if file_exists("tests/test-01-primitives.nx") {
        print("literal: true")
    } else {
        print("literal: false")
    }

    // Test 2: dynamic string via concatenation (like try_serve_static)
    let base_dir: String = "website/static"
    let url_path: String = "/style.css"
    let file_path: String = base_dir + url_path
    if file_exists(file_path) {
        print("dynamic: true")
    } else {
        print("dynamic: false")
    }

    // Test 3: subdirectory path (the failing case)
    let sub_path: String = "/learn/book.css"
    let sub_file: String = base_dir + sub_path
    if file_exists(sub_file) {
        print("subdir: true")
    } else {
        print("subdir: false")
    }

    // Test 4: non-existent file
    if file_exists("tests/nonexistent.nx") {
        print("missing: true")
    } else {
        print("missing: false")
    }
}
