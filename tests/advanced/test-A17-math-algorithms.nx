// Test A17: Algoritmos matemáticos
// Prueba: GCD, potencia modular, primos de Sieve

fn my_gcd(a: int, b: int) -> int {
    while b != 0 {
        let temp = b
        b = a % b
        a = temp
    }
    return a
}

fn power_mod(base: int, exp: int, modulus: int) -> int {
    var result = 1
    var b = base % modulus
    var e = exp
    while e > 0 {
        if e % 2 == 1 {
            result = (result * b) % modulus
        }
        e = e / 2
        b = (b * b) % modulus
    }
    return result
}

fn count_primes_below(n: int) -> int {
    // Simple sieve using array
    var is_prime = []
    var i = 0
    while i < n {
        if i < 2 {
            is_prime.push(0)
        } else {
            is_prime.push(1)
        }
        i = i + 1
    }

    i = 2
    while i * i < n {
        if is_prime[i] == 1 {
            var j = i * i
            while j < n {
                is_prime[j] = 0
                j = j + i
            }
        }
        i = i + 1
    }

    var count = 0
    i = 0
    while i < n {
        if is_prime[i] == 1 {
            count = count + 1
        }
        i = i + 1
    }
    return count
}

fn main() {
    print(my_gcd(48, 18))         // 6
    print(my_gcd(100, 75))        // 25
    print(power_mod(2, 10, 1000))  // 1024 % 1000 = 24
    print(count_primes_below(100)) // 25 primes below 100

    return 0
}
