// Test A10: Linked list simulada con arrays + maps
// Prueba: estructuras de datos dinámicas, punteros simulados

fn main() {
    // Simular linked list con un array de nodos
    // Cada nodo: [value, next_index] donde -1 = null
    var nodes = []

    // Crear lista: 10 -> 20 -> 30 -> null
    nodes.push([10, 1])    // nodo 0: valor=10, siguiente=1
    nodes.push([20, 2])    // nodo 1: valor=20, siguiente=2
    nodes.push([30, -1])   // nodo 2: valor=30, siguiente=-1 (null)

    // Recorrer la lista
    var current = 0
    var sum = 0
    while current != -1 {
        let node: Array = nodes[current]
        let val = node[0]
        print(val)
        sum = sum + val
        current = node[1]
    }

    // Suma = 60
    print(sum)

    return 0
}
