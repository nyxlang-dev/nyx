// Test A24: Closure Factory Pattern
// Combines: typed closures, closure factory, capture, compound assignment, compose

fn make_adder(n: int) -> Fn(int) -> int {
    fn add(x: int) -> int {
        return n + x
    }
    return add
}

fn make_multiplier(factor: int) -> Fn(int) -> int {
    fn mul(x: int) -> int {
        return x * factor
    }
    return mul
}

fn make_counter(start: int) -> Fn {
    var count = start
    fn next() -> int {
        count += 1
        return count
    }
    return next
}

fn make_accumulator(init: int) -> Fn {
    var total = init
    fn add_val(x: int) -> int {
        total += x
        return total
    }
    return add_val
}

fn apply_fn(func: Fn(int) -> int, x: int) -> int {
    return func(x)
}

fn apply_twice(func: Fn(int) -> int, x: int) -> int {
    let first = func(x)
    return func(first)
}

fn compose(fa: Fn(int)->int, ga: Fn(int)->int) -> Fn {
    fn inner(x: int) -> int {
        return fa(ga(x))
    }
    return inner
}

fn main() -> int {
    let add5: Fn(int) -> int = make_adder(5)
    let add10: Fn(int) -> int = make_adder(10)
    print(add5(3))
    print(add10(3))

    let times3: Fn(int) -> int = make_multiplier(3)
    print(times3(7))

    print(apply_fn(add5, 100))
    print(apply_fn(times3, 100))

    print(apply_twice(add5, 10))

    let composed = compose(times3, add5)
    print(composed(10))

    let counter = make_counter(0)
    print(counter())
    print(counter())
    print(counter())

    let acc = make_accumulator(0)
    print(acc(10))
    print(acc(20))
    print(acc(5))

    print("A24 passed")
    return 0
}
