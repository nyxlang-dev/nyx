// Test A04: Maps complejos — múltiples operaciones, conteo de frecuencias
// Prueba: Map como estructura de datos principal

fn main() {
    // Contar frecuencias de una secuencia
    var freq = Map.new()

    // Simular datos: 1,2,3,1,2,1
    let data = [1, 2, 3, 1, 2, 1]

    var i = 0
    while i < data.length() {
        let val = data[i]
        let key = int_to_string(val)
        if freq.contains(key) {
            let count = freq.get(key)
            freq.insert(key, count + 1)
        } else {
            freq.insert(key, 1)
        }
        i = i + 1
    }

    // freq["1"] = 3, freq["2"] = 2, freq["3"] = 1
    print(freq.get("1"))
    print(freq.get("2"))
    print(freq.get("3"))

    return 0
}
