// Test A07: Algoritmo de ordenamiento (bubble sort manual)
// Prueba: arrays mutables, algoritmos in-place

fn bubble_sort(arr: Array) {
    let n = arr.length()
    var i = 0
    while i < n - 1 {
        var j = 0
        while j < n - 1 - i {
            if arr[j] > arr[j + 1] {
                let temp = arr[j]
                arr[j] = arr[j + 1]
                arr[j + 1] = temp
            }
            j = j + 1
        }
        i = i + 1
    }
}

fn is_sorted(arr: Array) -> bool {
    var i = 0
    while i < arr.length() - 1 {
        if arr[i] > arr[i + 1] {
            return false
        }
        i = i + 1
    }
    return true
}

fn main() {
    var data = [64, 34, 25, 12, 22, 11, 90]

    if is_sorted(data) {
        print(1)
    } else {
        print(0)
    }

    bubble_sort(data)

    if is_sorted(data) {
        print(1)
    } else {
        print(0)
    }

    // Print sorted array
    var i = 0
    while i < data.length() {
        print(data[i])
        i = i + 1
    }

    return 0
}
