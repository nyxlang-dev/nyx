// Test 117: async executor — spawn_task + task_await (v0.7.3)
async fn square(n: int) -> int {
    return n * n
}

async fn slow_add(a: int, b: int) -> int {
    return a + b
}

fn main() {
    let t1 = spawn_task(square(3))
    let t2 = spawn_task(square(4))
    let t3 = spawn_task(square(5))

    let r1: int = task_await(t1)
    let r2: int = task_await(t2)
    let r3: int = task_await(t3)

    assert(r1 == 9)
    assert(r2 == 16)
    assert(r3 == 25)

    let t4 = spawn_task(slow_add(10, 20))
    let r4: int = task_await(t4)
    assert(r4 == 30)

    print("ok")
}
