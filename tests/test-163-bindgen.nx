// test-163-bindgen.nx — C binding generator verification
// Tests that nyx_bindgen correctly generates Nyx bindings from C declarations

// Since bindgen is a standalone binary (not a library), we test its output
// by parsing what it would generate — verifying the mapping logic directly.

fn map_c_type_basic(ctype: String) -> String {
    if ctype == "int" { return "i32" }
    if ctype == "long" { return "i64" }
    if ctype == "float" { return "f32" }
    if ctype == "double" { return "f64" }
    if ctype == "char" { return "i8" }
    if ctype == "void" { return "void" }
    if ctype == "bool" { return "bool" }
    if ctype == "size_t" { return "usize" }
    if ctype == "uint8_t" { return "u8" }
    if ctype == "int32_t" { return "i32" }
    if ctype == "int64_t" { return "i64" }
    return ctype
}

fn is_pointer_type(ctype: String) -> bool {
    let n = ctype.length()
    if n == 0 { return false }
    return ctype.substring(n - 1, n) == "*"
}

fn format_extern_fn(name: String, ret: String, params: String) -> String {
    return "extern \"C\" fn " + name + "(" + params + ") -> " + ret
}

fn format_repr_c_struct(name: String) -> String {
    return "#[repr(C)]\nstruct " + name + " {"
}

fn test_type_mapping() {
    print("--- Type Mapping ---")
    print(map_c_type_basic("int"))
    print(map_c_type_basic("long"))
    print(map_c_type_basic("float"))
    print(map_c_type_basic("double"))
    print(map_c_type_basic("void"))
    print(map_c_type_basic("size_t"))
    print(map_c_type_basic("int64_t"))
}

fn test_pointer_detection() {
    print("--- Pointer Detection ---")
    if is_pointer_type("int*") { print("int* is pointer") }
    if is_pointer_type("char*") { print("char* is pointer") }
    if not is_pointer_type("int") { print("int is not pointer") }
    if not is_pointer_type("void") { print("void is not pointer") }
}

fn test_extern_fn_format() {
    print("--- Extern Fn Format ---")
    print(format_extern_fn("add", "i32", "a: i32, b: i32"))
    print(format_extern_fn("greet", "*i8", "name: *i8"))
    print(format_extern_fn("free", "void", "ptr: *i8"))
}

fn test_repr_c_struct() {
    print("--- Repr C Struct ---")
    print(format_repr_c_struct("Point"))
    print("    x: i32,")
    print("    y: i32,")
    print("}")
}

fn test_define_const() {
    print("--- Define Constants ---")
    // Simulate #define parsing
    let defines: Array<String> = ["MAX_SIZE 1024", "VERSION 42", "PI_APPROX 3"]
    var i = 0
    while i < defines.length() {
        let def: String = defines[i]
        let space_idx = def.indexOf(" ")
        if space_idx > 0 {
            let name = def.substring(0, space_idx)
            let value = def.substring(space_idx + 1, def.length())
            print("const " + name + ": i32 = " + value)
        }
        i = i + 1
    }
}

fn test_enum_to_const() {
    print("--- Enum to Const ---")
    // C enums become const declarations in Nyx
    let enum_vals: Array<String> = ["RED", "GREEN", "BLUE"]
    var i = 0
    while i < enum_vals.length() {
        let name: String = enum_vals[i]
        print("const " + name + ": i32 = " + format("{}", i))
        i = i + 1
    }
}

fn main() {
    print("bindgen test")
    test_type_mapping()
    test_pointer_detection()
    test_extern_fn_format()
    test_repr_c_struct()
    test_define_const()
    test_enum_to_const()
    print("bindgen ok")
}
