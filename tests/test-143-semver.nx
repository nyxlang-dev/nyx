// test-143-semver: verifica el parser y comparador de versiones semver

import "std/semver" as semver

fn main() -> int {
    // Parsear versiones
    let v1 = semver.parse("1.2.3")
    print("major: " + v1.major)
    print("minor: " + v1.minor)
    print("patch: " + v1.patch)

    // Con prefijo v
    let v2 = semver.parse("v2.0.0")
    print("v2 major: " + v2.major)

    // Con pre-release
    let v3 = semver.parse("1.0.0-alpha.1")
    print("pre: " + v3.pre)

    // Comparar
    let cmp1: int = semver.compare("1.2.3", "1.3.0")
    print("1.2.3 vs 1.3.0: " + cmp1)

    let cmp2: int = semver.compare("2.0.0", "1.9.9")
    print("2.0.0 vs 1.9.9: " + cmp2)

    let cmp3: int = semver.compare("1.0.0", "1.0.0")
    print("1.0.0 vs 1.0.0: " + cmp3)

    // satisfies
    let s1: bool = semver.satisfies("1.5.0", ">=1.0.0")
    if s1 { print(">=1.0.0: ok") }

    let s2: bool = semver.satisfies("0.9.0", ">=1.0.0")
    if not s2 { print("0.9.0 fails >=1.0.0: ok") }

    let s3: bool = semver.satisfies("1.2.3", "^1.0.0")
    if s3 { print("^1.0.0: ok") }

    let s4: bool = semver.satisfies("2.0.0", "^1.0.0")
    if not s4 { print("2.0.0 fails ^1.0.0: ok") }

    let s5: bool = semver.satisfies("1.2.5", "~1.2.0")
    if s5 { print("~1.2.0: ok") }

    let s6: bool = semver.satisfies("1.3.0", "~1.2.0")
    if not s6 { print("1.3.0 fails ~1.2.0: ok") }

    // resolve best version
    var versions: Array = []
    versions.push("1.0.0")
    versions.push("1.1.0")
    versions.push("1.2.0")
    versions.push("2.0.0")
    let best: String = semver.resolve(versions, "^1.0.0")
    print("best ^1.0.0: " + best)

    // to_string
    let vs: String = semver.to_string(v1)
    print("to_string: " + vs)

    print("semver ok")
    return 0
}
