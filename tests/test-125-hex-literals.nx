// test-125-hex-literals.nx — Hex, binary, and octal literals (v1.2.0)

fn main() {
    // Hex literals
    let hex_ff: int = 0xFF
    let hex_10: int = 0x10
    let hex_dead: int = 0xDEAD
    let hex_upper: int = 0XFF

    // Binary literals
    let bin_5: int = 0b101
    let bin_8: int = 0b1000
    let bin_255: int = 0b11111111

    // Octal literals
    let oct_8: int = 0o10
    let oct_255: int = 0o377
    let oct_upper: int = 0O10

    // Arithmetic with literals
    let sum: int = 0xFF + 0b101

    print(hex_ff)
    print(hex_10)
    print(hex_dead)
    print(hex_upper)
    print(bin_5)
    print(bin_8)
    print(bin_255)
    print(oct_8)
    print(oct_255)
    print(oct_upper)
    print(sum)
}
