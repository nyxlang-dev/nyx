// test-23: map, filter, reduce con first-class functions
// Verifica: funciones de orden superior sobre arrays

fn array_map(arr: Array, f: Fn) -> Array {
    var result = []
    var i = 0
    while i < arr.length() {
        result.push(f(arr[i]))
        i = i + 1
    }
    return result
}

fn array_filter(arr: Array, predicate: Fn) -> Array {
    var result = []
    var i = 0
    while i < arr.length() {
        if predicate(arr[i]) == 1 {
            result.push(arr[i])
        }
        i = i + 1
    }
    return result
}

fn array_reduce(arr: Array, initial: int, f: Fn) -> int {
    var acc = initial
    var i = 0
    while i < arr.length() {
        acc = f(acc, arr[i])
        i = i + 1
    }
    return acc
}

fn double(n: int) -> int { return n * 2 }
fn square(n: int) -> int { return n * n }
fn is_positive(n: int) -> int { if n > 0 { return 1 } return 0 }
fn add(a: int, b: int) -> int { return a + b }
fn multiply(a: int, b: int) -> int { return a * b }

fn main() {
    let nums = [1, 2, 3, 4, 5]

    // map: double each
    let doubled = array_map(nums, double)
    print(doubled[0])  // 2
    print(doubled[4])  // 10

    // map: square each
    let squared = array_map(nums, square)
    print(squared[2])  // 9

    // filter: positive from [-2, -1, 0, 1, 2]
    let mixed = [-2, -1, 0, 1, 2]
    let positives = array_filter(mixed, is_positive)
    print(positives.length())  // 2
    print(positives[0])        // 1

    // reduce: sum
    let total = array_reduce(nums, 0, add)
    print(total)  // 15

    // reduce: product
    let product = array_reduce(nums, 1, multiply)
    print(product)  // 120

    return 0
}
